# ---- Email SMTP (notifiche transazionali) ----
# Funziona con una casella propria o con Brevo/Resend SMTP.
# Se vuote, le email sono no-op (log a console): l'app continua a funzionare.
SMTP_HOST=smtp.tuoprovider.it
SMTP_PORT=587                            # 587 STARTTLS · 465 SSL
SMTP_USER=noreply@washloop.it
SMTP_PASS=...
SMTP_FROM=WashLoop <noreply@washloop.it>
