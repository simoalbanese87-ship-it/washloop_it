# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # SOLO server, mai esposta al client

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Email SMTP (notifiche transazionali) ----
# Provider consigliato: Brevo (free 300/giorno, buona deliverability).
# Se vuote, le email sono no-op (log a console): l'app continua a funzionare.
# Brevo: SMTP & API -> SMTP -> login = email account Brevo, pass = SMTP key.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587                            # 587 STARTTLS (Brevo) · 465 SSL (Aruba)
SMTP_USER=                              # Brevo: la tua email account Brevo
SMTP_PASS=                              # Brevo: la SMTP key (non la password account)
SMTP_FROM=WashLoop <noreply@washloop.it>  # mittente VERIFICATO in Brevo

# ---- Brevo (API v3, sola lettura stato invii — admin/email) ----
BREVO_API_KEY=xkeysib-...

# ---- Funnel lista d'attesa (Google Sheet via Apps Script) ----
# Vedi scripts/funnel-sheet-webapp.gs per pubblicare la Web App sul foglio.
FUNNEL_SHEET_URL=https://script.google.com/macros/s/xxxx/exec
FUNNEL_SHEET_TOKEN=                       # lo stesso TOKEN impostato nell'Apps Script
